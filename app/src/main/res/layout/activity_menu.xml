<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#F8FAFF">

    <!-- Title -->
    <TextView
        android:text="TIC TAC TOE"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FF00FF"
        android:layout_marginBottom="24dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- ĐỎ -->
    <Button
        android:id="@+id/btn3x3"
        android:text="Chơi 3 x 3"
        android:backgroundTint="#FF3B30"
        android:textColor="#FFFFFF"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- CAM -->
    <Button
        android:id="@+id/btn6x6"
        android:text="Chơi 6 x 6"
        android:layout_marginTop="8dp"
        android:backgroundTint="#FF9500"
        android:textColor="#FFFFFF"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- VÀNG -->
    <Button
        android:id="@+id/btn9x9"
        android:text="Chơi 9 x 9"
        android:layout_marginTop="8dp"
        android:backgroundTint="#FFCC00"
        android:textColor="#000000"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- XANH LÁ -->
    <Button
        android:id="@+id/btn10x10"
        android:text="Chơi 10 x 10"
        android:layout_marginTop="8dp"
        android:backgroundTint="#34C759"
        android:textColor="#FFFFFF"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- XANH DƯƠNG -->
    <Button
        android:id="@+id/btnCustom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chơi kích thước tùy chỉnh"
        android:layout_marginTop="12dp"
        android:backgroundTint="#007AFF"
        android:textColor="#FFFFFF"/>

    <!-- NumberPicker -->
    <NumberPicker
        android:id="@+id/numberPickerSize"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:layout_gravity="center_horizontal"
        android:background="#E0E7FF" />

    <!-- Switch -->
    <Switch
        android:id="@+id/switchBot"
        android:text="Chơi với máy (AI)"
        android:textColor="#111827"
        android:layout_marginTop="24dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/btnHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Xem lịch sử đấu"
        android:textSize="18sp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#3F51B5"
        android:textColor="#FFFFFF"/>

</LinearLayout>